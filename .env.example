# Cloudflare API Keys
# Sign up at: https://dash.cloudflare.com/sign-up

# Get your API Token:
# 1. Go to Dashboard → Profile → API Tokens
# 2. Create Custom Token with following permissions:
#    - Zone:Read, Zone:DNS:Edit
#    - Account:Read, Account:Workers:Edit
#    - Stream:Read, Stream:Write

CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# For Cloudflare Stream (video hosting):
# https://www.cloudflare.com/products/stream/

# For Cloudflare R2 (object storage):
# https://www.cloudflare.com/products/r2/

# Get your Account ID from: https://dash.cloudflare.com/:accountId/overview